#--------------------------------------Scripts TIM-----------------------------------
$scriptsTim = @(
    [pscustomobject]@{
        Nome = "Fechar Cisco/CallControl"
        Acao = {
            if (-not (Get-SSCredential)) { return }	
            Write-Host " Fechando processos..." -ForegroundColor Cyan

            Get-Process -Name @('cis*','mb*','*hide*','comm*','2comm*') -ErrorAction SilentlyContinue |
                Stop-Process -Force -ErrorAction SilentlyContinue

            Write-Host " Finalizado!" -ForegroundColor Green
        }
    }

	[pscustomobject]@{
		Nome = "Configura Cisco"
		Acao = {
			if (-not (Get-SSCredential)) { return }	

			$cisoRegPath32 = "HKLM:\SOFTWARE\WOW6432Node\Cisco Systems, Inc.\Cisco IP Communicator"
			$ramal = $null
			$site = $null

			$user = (Read-Host "Informe o PIN ou usuário").Trim()

			$searchResult = Search-RamalPinTim -LookupValue $user
			if ($searchResult) {
				$ramal = $searchResult.Ramal
				$site = $searchResult.Site
			}

			if ([string]::IsNullOrEmpty($ramal)) {
				Write-Host " Login/PIN não localizado." -ForegroundColor Yellow
				
				$retryOptions = @("Tentar novamente", "Digitar manualmente")
				$retryChoice = $null
				Select-FromMenu -Options $retryOptions -OutputVariable ([ref]$retryChoice) -Prompt "Deseja tentar novamente ou digitar o ramal manualmente?"

				if ($retryChoice -eq "Tentar novamente") {
					$user = (Read-Host " Informe o PIN ou usuário").Trim()
					$searchResult = Search-RamalPinTim -LookupValue $user
					if ($searchResult) {
						$ramal = $searchResult.Ramal
						$site = $searchResult.Site
					}
				}
			}
			while ([string]::IsNullOrEmpty($site)) {
				if ([string]::IsNullOrEmpty($ramal)) {
					$ramal = Read-Host " Ramal"
				}
				
				if ($ramal -notmatch '^\d{7}$') {
					Write-Host " Ramal inválido. Ramal deve ter 7 dígitos." -ForegroundColor Red
					$ramal = $null
					continue
				}

				$site = Get-TimSiteFromRamal -Ramal $ramal
				if ([string]::IsNullOrEmpty($site)) {
					Write-Host " Ramal inválido. Ramal TIM começa com 312 ou 382." -ForegroundColor Red
					$ramal = $null
					$site = $null
				}
			}

			Write-Host " Configurando Cisco para o ramal $ramal do site $site..." -ForegroundColor Cyan
			if (Test-Path $cisoRegPath32) {
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "AlternateDeviceName" -Type "DWord" -Value 1
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "NetworkTabUI" -Type "DWord" -Value 2
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "EnableHttpDownload" -Type "DWord" -Value 1
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "TftpServer1" -Type "DWord" -Value 3229591562
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "TftpServer2" -Type "DWord" -Value 2206167050
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "AlternateTftp" -Type "DWord" -Value 1
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "EnableSIP" -Type "String" -Value "AEC_$site`_$ramal"
			}
			Write-Host " Configuração concluída!" -ForegroundColor Green
		}
	}
	
	[pscustomobject]@{
		Nome = "Configura CallControl"
		Acao = {
			if (-not (Get-SSCredential)) { return }	

			$pin = $null
			$lookupValue = (Read-Host "Informe o PIN ou usuário").Trim()
			$searchResult = Search-RamalPinTim -LookupValue $lookupValue
			if ($searchResult) {
				$pin = $searchResult.Pin
			}

			if ([string]::IsNullOrEmpty($pin)) {
				Write-Host " Login/PIN não localizado." -ForegroundColor Yellow
				
				$retryOptions = @("Tentar novamente", "Digitar manualmente")
				$retryChoice = $null
				Select-FromMenu -Options $retryOptions -OutputVariable ([ref]$retryChoice) -Prompt "Deseja tentar novamente ou digitar o PIN manualmente?"

				if ($retryChoice -eq "Tentar novamente") {
					$lookupValue = (Read-Host " Informe o PIN ou usuário novamente").Trim()
					$searchResult = Search-RamalPinTim -LookupValue $lookupValue
					if ($searchResult) {
						$pin = $searchResult.Pin
					}
				}
			}

			while ([string]::IsNullOrEmpty($pin)) {
				$pin = (Read-Host " Digite o PIN").Trim()

				if ($pin -notmatch '^\d{7}$') {
					Write-Host " PIN inválido. PIN deve conter 7 dígitos." -ForegroundColor Red
					$pin = $null
					continue
				}

				if ($pin -notmatch '^(383|313)') {
					Write-Host " PIN inválido. PIN deve começar com 383 ou 313." -ForegroundColor Red
					$pin = $null
					continue
				}
			}

			Write-Host " Configurando CallControl para o PIN $pin..." -ForegroundColor Cyan
			Edit-Reg -Action "Create" -Path "HKCU:\Environment" -Name "AgentID" -Type "String" -Value "$pin" | Out-Null
			Write-Host " Configuração concluída!" -ForegroundColor Green
		}
	}
	[pscustomobject]@{
		Nome = "Ajusta Proxy TIM"
		Acao = {
			if (-not (Get-SSCredential)) { return }	

			$proxyRegPath = "HKCU:\Software\Microsoft\Windows\CurrentVersion\Internet Settings"
			if (-not (Test-Path $proxyRegPath)) {
				New-Item -Path $proxyRegPath -Force | Out-Null
			}
			$currentProxyEnable = Search-Reg -Path $proxyRegPath -Name "ProxyEnable"
			$currentProxyServer = Search-Reg -Path $proxyRegPath -Name "ProxyServer"
			$currentProxyOverride = Search-Reg -Path $proxyRegPath -Name "ProxyOverride"

			$proxyModeOptions = @("Automático", "Manual")
			$proxyModeChoice = $null
			Select-FromMenu -Options $proxyModeOptions -OutputVariable ([ref]$proxyModeChoice) -Prompt "Escolha o modo de configuração do proxy TIM:"

			if ([string]::IsNullOrEmpty($proxyModeChoice)) {
				Write-Host " Operação cancelada." -ForegroundColor Yellow
				return
			}

			Write-Host " Configurando proxy para a TIM..." -ForegroundColor Cyan

			if ($proxyModeChoice -eq "Automático") {
				Edit-Reg -Action "Create" -Path $proxyRegPath -Name "ProxyEnable" -Type "DWord" -Value 1
				Edit-Reg -Action "Create" -Path $proxyRegPath -Name "ProxyServer" -Type "String" -Value "192.168.66.150:8080"
				Edit-Reg -Action "Create" -Path $proxyRegPath -Name "ProxyOverride" -Type "String" -Value "10.*;192.*;172.*;62.101.*;200.198.*;*.timbrasil.com.br;*.timsul.com.br;*.timint;*.tim.it;*.grupoaec.com.br;*.grupoaec.local;aplicacoestim;SNEP*;capps*;RJO*;rjocpdwe03;rjocpdwi07;ccare.blah.com;timbr.upstreamsystems.com;timx-search-prd-001*;exchange2016.aec.com.br;exchange2-2016.aec.com.br;spaceplanning-dev.azure-devices.net;snepsto01v;cbcf;sage;simig;br.msn.com;minhaaec;minhaaec.grupoaec.com.br;authb2b2c.tim.com.br;auth3b2b2c.tim.com.br;*googleapis.com;<local>"
				Write-Host " Configuração concluída!" -ForegroundColor Green
				return
			}

			$manualValues = Show-ProxyForm `
				-CurrentProxyEnable $currentProxyEnable `
				-CurrentProxyServer $(if ($null -eq $currentProxyServer) { "" } else { [string]$currentProxyServer }) `
				-CurrentProxyOverride $(if ($null -eq $currentProxyOverride) { "" } else { [string]$currentProxyOverride })

			if ($null -eq $manualValues) {
				Write-Host " Operação cancelada." -ForegroundColor Yellow
				return
			}

			Edit-Reg -Action "Create" -Path $proxyRegPath -Name "ProxyEnable" -Type "DWord" -Value $manualValues.ProxyEnable
			Edit-Reg -Action "Create" -Path $proxyRegPath -Name "ProxyServer" -Type "String" -Value $manualValues.ProxyServer
			Edit-Reg -Action "Create" -Path $proxyRegPath -Name "ProxyOverride" -Type "String" -Value $manualValues.ProxyOverride

			Write-Host " Configuração concluída!" -ForegroundColor Green
		}
	}
)

