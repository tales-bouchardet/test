function Select-FromMenu {
	param(
		[Parameter(Mandatory=$true)][array]$Options,
		[Parameter(Mandatory=$true)][ref]$OutputVariable,
		[Parameter(Mandatory=$true)][string]$Prompt
	)

	$selectedIndex = 0

	function Write-OptionItem {
		param(
			[int]$Index,
			[bool]$IsSelected,
			[int]$TopLine
		)

		[Console]::SetCursorPosition(0, $TopLine + $Index)
		$label = "  $($Options[$Index])"
		$lineText = $label.PadRight([Math]::Max([Console]::WindowWidth - 1, $label.Length))
		if ($IsSelected) {
			Write-Host " > $lineText" -ForegroundColor Green -NoNewline
		} else {
			Write-Host "   $lineText" -ForegroundColor White -NoNewline
		}
	}

	Clear-Host
	Write-Host ""
	Write-Host " $Prompt" -ForegroundColor Cyan
	Write-Host ""
	$menuTop = [Console]::CursorTop

	for ($i = 0; $i -lt $Options.Count; $i++) {
		Write-OptionItem -Index $i -IsSelected ($i -eq $selectedIndex) -TopLine $menuTop
	}

	[Console]::CursorVisible = $false
	try {
		:KeyLoop while ($true) {
			$key = [Console]::ReadKey($true)
			switch ($key.Key) {
				"UpArrow" {
					$previousIndex = $selectedIndex
					if ($selectedIndex -gt 0) { $selectedIndex-- } else { $selectedIndex = $Options.Count - 1 }
					Write-OptionItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
					Write-OptionItem -Index $selectedIndex -IsSelected $true -TopLine $menuTop
				}
				"DownArrow" {
					$previousIndex = $selectedIndex
					if ($selectedIndex -lt ($Options.Count - 1)) { $selectedIndex++ } else { $selectedIndex = 0 }
					Write-OptionItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
					Write-OptionItem -Index $selectedIndex -IsSelected $true -TopLine $menuTop
				}
				"Enter" {
					$OutputVariable.Value = $Options[$selectedIndex]
					break KeyLoop
				}
				"Escape" {
					break KeyLoop
				}
			}
		}
	} finally {
		[Console]::CursorVisible = $true
	}
	Clear-Host
}

function Show-FirstMenu {
	param(
		[array]$Items,
		[int]$SelectedIndex = 0,
		[bool]$PauseAfterAction = $true,
		[bool]$IsRootMenu = $false
	)

	function Write-MenuItem {
		param(
			[int]$Index,
			[bool]$IsSelected,
			[int]$TopLine
		)

		[Console]::SetCursorPosition(0, $TopLine + $Index)
		$label = "  $($Items[$Index].Nome)"
		$lineText = $label.PadRight([Math]::Max([Console]::WindowWidth - 1, $label.Length))
		if ($IsSelected) {
			Write-Host " > $lineText" -ForegroundColor Green -NoNewline
		} else {
			Write-Host "   $lineText" -ForegroundColor White -NoNewline
		}
	}

	while ($true) {
		Clear-Host
		$escActionText = if ($IsRootMenu) { "sair" } else { "voltar" }
		Write-Host ""
		Write-Host (" ↑ e ↓ para navegar, Enter para executar, Esc para {0}." -f $escActionText) -ForegroundColor Cyan
		Write-Host ""
		$menuTop = [Console]::CursorTop

		for ($i = 0; $i -lt $Items.Count; $i++) {
			Write-MenuItem -Index $i -IsSelected ($i -eq $SelectedIndex) -TopLine $menuTop
		}

		[Console]::CursorVisible = $false
		try {
			:KeyLoop while ($true) {
				$key = [Console]::ReadKey($true)
				switch ($key.Key) {
					"UpArrow" {
						$previousIndex = $SelectedIndex
						if ($SelectedIndex -gt 0) { $SelectedIndex-- } else { $SelectedIndex = $Items.Count - 1 }
						Write-MenuItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
						Write-MenuItem -Index $SelectedIndex -IsSelected $true -TopLine $menuTop
					}
					"DownArrow" {
						$previousIndex = $SelectedIndex
						if ($SelectedIndex -lt ($Items.Count - 1)) { $SelectedIndex++ } else { $SelectedIndex = 0 }
						Write-MenuItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
						Write-MenuItem -Index $SelectedIndex -IsSelected $true -TopLine $menuTop
					}
					"Enter" {
						break KeyLoop
					}
					"Escape" {
						return
					}
				}
			}
		} finally {
			[Console]::CursorVisible = $true
		}

		Clear-Host
		$selected = $Items[$SelectedIndex]
		Write-Host (" Executando: {0}" -f $selected.Nome) -ForegroundColor Cyan
		Write-Host "-------------------------------------------" -ForegroundColor DarkGray
		try {
			& $selected.Acao
		} catch {
			Write-Host ""
			Write-Host (" Erro: {0}" -f $_.Exception.Message) -ForegroundColor Red
		}
		if ($PauseAfterAction) {
			Write-Host ""
			Write-Host " Pressione qualquer tecla para voltar ao menu..." -ForegroundColor Gray
			[void][Console]::ReadKey($true)
		}
		$SelectedIndex = 0
	}
}

function Show-SegmentMenu {
	param(
		[Parameter(Mandatory=$true)][hashtable]$Segments
	)

	$orderedSegments = @("Geral", "Claro", "Oi", "Tim") | Where-Object { $Segments.ContainsKey($_) }
	$segmentItems = foreach ($segmentName in $orderedSegments) {
		$collection = $Segments[$segmentName]
		[pscustomobject]@{
			Nome = $segmentName
			Acao = { Show-FirstMenu -Items $collection }.GetNewClosure()
		}
	}

	Show-FirstMenu -Items $segmentItems -PauseAfterAction:$false -IsRootMenu:$true
}

function Search-RamalPinTim {
	param(
		[Parameter(Mandatory=$true)][string]$LookupValue
	)

	$resp = (Invoke-WebRequest -Uri "\\romulo\script_tim.$\Ramal_TIM\RamalP.txt" -UseBasicParsing -ErrorAction SilentlyContinue).RawContent
	Write-Host " Buscando ramal para '$LookupValue'..." -ForegroundColor Cyan

	$lookupNormalized = $LookupValue.Trim()
	$lookupPin = ($lookupNormalized -replace '\D', '')
	if ($resp) {
		$lines = $resp -split "`r?`n"

		foreach ($line in $lines) {
			if ([string]::IsNullOrWhiteSpace($line)) { continue }

			$parts = $line.Split(',')
			if ($parts.Count -lt 3) { continue }

			$pinCandidate    = $parts[0].Trim().Trim([char]0xFEFF)
			$ramalCandidate  = $parts[1].Trim()
			$userCandidate   = $parts[2].Trim()

			$pinCandidateNormalized = ($pinCandidate -replace '\D', '')
			$isPinMatch = ($lookupPin.Length -gt 0 -and $lookupPin -eq $pinCandidateNormalized)
			$isUserMatch = $lookupNormalized.Equals($userCandidate, [System.StringComparison]::OrdinalIgnoreCase)

			if (-not ($isPinMatch -or $isUserMatch)) { continue }

			if ($ramalCandidate -notmatch '^\d{7}$') { continue }

			switch ($ramalCandidate.Substring(0, 3)) {
				"312" { $resolvedSite = "BH" }
				"382" { $resolvedSite = "MOC" }
				default { continue }
			}

			return [pscustomobject]@{
				Pin   = $pinCandidateNormalized
				Ramal = $ramalCandidate
				Site  = $resolvedSite
			}
		}
	}

	return $null
}

