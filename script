				Write-Host "Erro: nenhuma operação escolhida" -ForegroundColor Red
				return
			}

			$hostsDir = "$env:SystemRoot\System32\drivers\etc\hosts"

			switch ($operacao) {
				"MOC" {
					$networkPath = "\\romulo.grupoaec.com.br\script_tim.$\Hosts\HOSTS"
					if (-not (Copy-ItemSafe -Path $networkPath -Destination $hostsDir)) { return }
				}
				"ORI" {
					$networkPath = "\\mercurio-vm2\script_tim_ipcc.$\Host\HOSTS"
					if (-not (Copy-ItemSafe -Path $networkPath -Destination $hostsDir)) { return }
				}
				"RJO" {
					$networkPath = "\\pamela2.grupoaec.com.br\script_tim.$\Host\HOSTS"
					if (-not (Copy-ItemSafe -Path $networkPath -Destination $hostsDir)) { return }
				}
				default { Write-Host "Operação inválida" -ForegroundColor Red }
			}
		}
	}
)

