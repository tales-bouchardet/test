    $form.MaximizeBox = $false
    $form.MinimizeBox = $false

    function Add-Field($label, $y, $text, $multiLine = $false, $height = 23) {
        $lbl = New-Object Windows.Forms.Label
        $lbl.Text = $label
        $lbl.Location = New-Object Drawing.Point(10,$y)
        $lbl.AutoSize = $true
        $form.Controls.Add($lbl)

        $txt = New-Object Windows.Forms.TextBox
        $txt.Location = New-Object Drawing.Point(150,$y)
        $txt.Size = New-Object Drawing.Size(250,$height)
        $txt.Multiline = $multiLine
