function Get-ActiveUser {
	$rawUser = (query user | Select-String 'Ativo|Active' | ForEach-Object { ($_ -split '\s+')[0] })
	return $rawUser.TrimStart('>')
}

function Get-ActiveUserSid {
	$user = Get-ActiveUser
	return (Get-ItemProperty 'HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\ProfileList\*' | Where-Object { $_.ProfileImagePath -eq "C:\Users\$user" }).PSChildName
}

function Edit-Reg {
	param(
		[Parameter(Mandatory=$false)][ValidateSet("Create","Remove")][string]$Action = "Create",
		[Parameter(Mandatory=$true)][string]$Path,
		[Parameter(Mandatory=$false)][ValidateSet("Item","Property")][string]$Target = "Property",
		[Parameter(Mandatory=$false)][Alias("Name")][string]$PName,
		[Parameter(Mandatory=$false)][ValidateSet("DWord","String")][string]$Type,
		[Parameter(Mandatory=$false)]$Value
	)
				
	$sid = Get-ActiveUserSid
	
	if ($Path -like 'HKCU:\*') {
		$regPath = $Path -replace 'HKCU:', "Registry::HKEY_USERS\$sid"

	}
	elseif ($Path -like 'ADM:\*') {
		$regPath = $Path -replace '^ADM:', "HKCU:"
	}
	else {
		$regPath = $Path
	}

	
	if ($Action -eq "Remove") {
		try {
			if ($Target -eq "Item") {
				Remove-Item -Path $regPath -Recurse -Force -ErrorAction SilentlyContinue
			} else {
				Remove-ItemProperty -Path $regPath -Name $PName -ErrorAction SilentlyContinue
			}
		} catch {
			Write-Host ("Erro ao remover a chave: {0}" -f $_.Exception.Message) -ForegroundColor Red
		}
		return
	}
	
	if (-not (Test-Path $regPath)) { New-Item -Path $regPath -Force | Out-Null }
	if ($Target -ne "Property") { return }
	try {
		if ($Type -eq "DWord") {
			New-ItemProperty -Path $regPath -Name $PName -Value ([int]$Value) -PropertyType DWord -Force | Out-Null
		} else {
			New-ItemProperty -Path $regPath -Name $PName -Value ([string]$Value) -PropertyType String -Force | Out-Null
		}
	} catch {
		Write-Host ("Erro ao criar/editar a chave: {0}" -f $_.Exception.Message) -ForegroundColor Red
	}
}

function Search-Reg {
	param(
		[Parameter(Mandatory=$true)][string]$Path,
		[Parameter(Mandatory=$false)][Alias("Name")][string]$PName
	)

	$sid = Get-ActiveUserSid

	$regPath = if ($Path -like 'HKCU:\*') {
		$Path -replace '^HKCU:', "Registry::HKEY_USERS\$sid"
	} elseif ($Path -like 'HKCU:\*') {
		$Path -replace '^HKCU:', "Registry::HKEY_USERS\$sid"
	} elseif ($Path -like 'ADM:\*') {
		$Path -replace '^ADM:', "HKCU:"
	} else {
		$Path
	}

	if (-not (Test-Path $regPath)) { return $null }

	try {
		if ([string]::IsNullOrEmpty($PName)) {
			return Get-ItemProperty -Path $regPath -ErrorAction SilentlyContinue
		}

		$propertyBag = Get-ItemProperty -Path $regPath -ErrorAction SilentlyContinue
		if ($null -eq $propertyBag) { return $null }

		return $propertyBag.$PName
	} catch {
		Write-Host ("Erro ao consultar a chave: {0}" -f $_.Exception.Message) -ForegroundColor Red
		return $null
	}
}

function Show-ProxyForm {
    param(
        $CurrentProxyEnable,
        [string]$CurrentProxyServer,
        [string]$CurrentProxyOverride
    )

    Add-Type -AssemblyName System.Windows.Forms
    Add-Type -AssemblyName System.Drawing

    $form = New-Object Windows.Forms.Form
    $form.Text = "Proxy Form"
    $form.Size = New-Object Drawing.Size(430,250)
    $form.StartPosition = "CenterScreen"
    $form.FormBorderStyle = "FixedDialog"
    $form.MaximizeBox = $false
    $form.MinimizeBox = $false

    function Add-Field($label, $y, $text, $multiLine = $false, $height = 23) {
        $lbl = New-Object Windows.Forms.Label
        $lbl.Text = $label
        $lbl.Location = New-Object Drawing.Point(10,$y)
        $lbl.AutoSize = $true
        $form.Controls.Add($lbl)

        $txt = New-Object Windows.Forms.TextBox
        $txt.Location = New-Object Drawing.Point(150,$y)
        $txt.Size = New-Object Drawing.Size(250,$height)
        $txt.Multiline = $multiLine
        if ($multiLine) { $txt.ScrollBars = "Vertical" }
        $txt.Text = $text
        $form.Controls.Add($txt)

        return $txt
    }

    $chkEnable = New-Object Windows.Forms.CheckBox
    $chkEnable.Text = "Habilitar Proxy"
    $chkEnable.Location = New-Object Drawing.Point(10,20)
    $chkEnable.AutoSize = $true
    $chkEnable.Checked = ([int]$CurrentProxyEnable -eq 1)
    $form.Controls.Add($chkEnable)

    $txtServer   = Add-Field "ProxyServer:"   55  $CurrentProxyServer
    $txtOverride = Add-Field "ProxyOverride:" 90  $CurrentProxyOverride $true 70

    $txtServer.Enabled = $chkEnable.Checked

    $chkEnable.Add_CheckedChanged({
        $txtServer.Enabled = $chkEnable.Checked
    })

    # Botões levemente mais abaixo
    $btnOk = New-Object Windows.Forms.Button
    $btnOk.Text = "Salvar"
    $btnOk.Size = New-Object Drawing.Size(75,28)
    $btnOk.Location = New-Object Drawing.Point(245,175)
    $form.Controls.Add($btnOk)

