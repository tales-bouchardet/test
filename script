			$testMinhaAec = Test-Connection -ComputerName "minhaaec" -Count 2 -Quiet -ErrorAction SilentlyContinue
			if (-not $testMinhaAec) {
				Write-Host " Ajustando configuração de DNS..." -ForegroundColor Cyan
				Set-DnsClientGlobalSetting -SuffixSearchList @($dominio)
				Start-Sleep -Seconds 2

				if (-not $testMinhaAec) {
					Write-Host " Não foi possível validar a rede interna, verifique a VPN." -ForegroundColor Yellow
					return
				}
			}

			if (-not (Test-Connection "192.168.88.8" -Count 2 -Quiet) -and
			    -not (Test-Connection "$dominio" -Count 2 -Quiet)) {
				Write-Host " Não há conexão com o servidor interno ($dominio)." -ForegroundColor Yellow
				return
			}

			Write-Host " Selecionando o melhor servidor..." -ForegroundColor Cyan
			Write-Host ""
			$servers = "DGT_PUBL_$selectedSite", "AZURE-SRV01"

			$bestServer = $servers | ForEach-Object {
				try {
					$pingResult = Test-Connection $_ -Count 2 -ErrorAction Stop | Measure-Object ResponseTime -Average
					if ($pingResult) {
						$r = $pingResult.Average
						[PSCustomObject]@{Server=$_; Latency=$r}
					}
				} catch {}
			} | Sort-Object Latency | Select-Object -First 1

            if ($bestServer -and $bestServer.Server -ne "AZURE-SRV01") {
                $tologadoPath = "\\$($bestServer.Server)\to_logado.$\Squirrel\setup.exe"
            } else {
                $tologadoPath = "\\AZURE-SRV01\tologado_ho.$\Squirrel\setup.exe"
            }

			Write-Host (" Servidor selecionado: {0} (latência média: {1} ms)" -f $bestServer.Server, $bestServer.Latency) -ForegroundColor Green
            
			Get-Process aec*,self*,setup*,chromed* -ErrorAction SilentlyContinue | Stop-Process -Force -ErrorAction SilentlyContinue

			$user = Get-ActiveUser

			Write-Host " Preparando arquivos..." -ForegroundColor Cyan
            Remove-Item "C:\aec\setup.exe" -Force -ErrorAction SilentlyContinue
            Remove-Item "C:\Users\$user\Desktop\tô logado*" -Force -ErrorAction SilentlyContinue
            Remove-Item "C:\Users\$user\AppData\Local\ToLogado*" -Force -ErrorAction SilentlyContinue

			Write-Host " Copiando instalador para C:\AEC..." -ForegroundColor Cyan
            New-Item -Path "C:\AEC" -ItemType Directory -Force | Out-Null
            Copy-Item $tologadoPath "C:\AEC\Setup_ToLogado.exe" -Force

			Write-Host " Criando atalho na área de trabalho..." -ForegroundColor Cyan
            $WshShell = New-Object -ComObject WScript.Shell
            $Shortcut = $WshShell.CreateShortcut("C:\Users\$user\Desktop\Setup_ToLogado.lnk")
            $Shortcut.TargetPath = "C:\AEC\Setup_ToLogado.exe"
            $Shortcut.Save()
			
			Write-Host " Execute o atalho 'Setup_ToLogado' na área de trabalho para iniciar a instalação." -ForegroundColor Green
			Write-Host " Configuração concluída!" -ForegroundColor Green
		}
	}
)

