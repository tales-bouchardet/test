taskkill /f /im team* /im tv*

Get-Package -Name "TeamViewer*" -ErrorAction SilentlyContinue |
    Uninstall-Package -Force -ErrorAction SilentlyContinue

Remove-Item "HKLM:\SOFTWARE\TeamViewer" -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item "HKLM:\SOFTWARE\WOW6432Node\TeamViewer" -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\TeamViewer" -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item "HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\TeamViewer" -Recurse -Force -ErrorAction SilentlyContinue

if (Test-Path "C:\Program Files\TeamViewer\uninstall.exe") {
    & "C:\Program Files\TeamViewer\uninstall.exe" /S
}
if (Test-Path "C:\Program Files (x86)\TeamViewer\uninstall.exe") {
    & "C:\Program Files (x86)\TeamViewer\uninstall.exe" /S
}

Start-Sleep 20

Remove-Item "C:\Program Files\TeamViewer" -Recurse -Force -ErrorAction SilentlyContinue
Remove-Item "C:\Program Files (x86)\TeamViewer" -Recurse -Force -ErrorAction SilentlyContinue

Get-ChildItem Registry::HKEY_USERS | ForEach-Object {
    Remove-Item "Registry::$($_.Name)\Software\TeamViewer" -Recurse -Force -ErrorAction SilentlyContinue
}

reg.exe import "$PSScriptRoot\TeamViewer_Settings.reg"

Start-Process msiexec.exe -Wait -ArgumentList "/i `"$PSScriptRoot\TeamViewer_Host.msi`" /qb! SETTINGSFILE=`"$PSScriptRoot\TeamViewer_Settings.tvopt`""

if (-not (Get-Process TeamViewerQS -ErrorAction SilentlyContinue)) {
    & "$PSScriptRoot\TeamViewerQS.exe" /S
}

if (Test-Path "C:\Program Files\TeamViewer\TeamViewer.exe") {
    Get-ChildItem C:\Users -Directory | ForEach-Object {
        Remove-Item "$($_.FullName)\Desktop\TeamVi*" -Recurse -Force -ErrorAction SilentlyContinue
    }

    $wsh = New-Object -ComObject WScript.Shell
    $sc = $wsh.CreateShortcut("C:\Users\Public\Desktop\TeamViewer.lnk")
    $sc.TargetPath = "C:\Program Files\TeamViewer\TeamViewer.exe"
    $sc.Save()
}
