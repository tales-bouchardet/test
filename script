    $btnCancel.Text = "Cancelar"
    $btnCancel.Size = New-Object Drawing.Size(75,28)
    $btnCancel.Location = New-Object Drawing.Point(325,175)
    $form.Controls.Add($btnCancel)

    $btnOk.Add_Click({
        $form.Tag = [pscustomobject]@{
            ProxyEnable   = if ($chkEnable.Checked) { 1 } else { 0 }
            ProxyServer   = $txtServer.Text.Trim()
            ProxyOverride = $txtOverride.Text.Trim()
        }

        $form.DialogResult = "OK"
        $form.Close()
    })

    $btnCancel.Add_Click({ $form.Close() })

    if ($form.ShowDialog() -ne "OK") { return $null }
    return $form.Tag
