function Get-SSCredential {
    $storedHash = "ad43282ea5d872ed9fdb3306e75ed712286a6478c597a05e4bb5ad2eb0d1c70f"

    $inputSecure = Read-Host "Senha" -AsSecureString
    $inputPlain  = [System.Net.NetworkCredential]::new("", $inputSecure).Password

    $sha256 = New-Object System.Security.Cryptography.SHA256Managed
    $inputHash = $sha256.ComputeHash([Text.Encoding]::UTF8.GetBytes($inputPlain))
    $inputHashHex = -join ($inputHash | ForEach-Object { $_.ToString("x2") })

