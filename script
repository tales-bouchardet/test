                Stop-Process -Force -ErrorAction SilentlyContinue

            Write-Host " Finalizado!" -ForegroundColor Green
        }
    }
	[pscustomobject]@{
		Nome = "Configura Cisco"
		Acao = {
			if (-not (Get-SSCredential)) { return }	

			$cisoRegPath32 = "HKLM:\SOFTWARE\WOW6432Node\Cisco Systems, Inc.\Cisco IP Communicator"
			$ramal = $null
			$site = $null

			$user = (Read-Host "Informe o PIN ou usuário").Trim()

			$searchResult = Search-RamalPinTim -LookupValue $user
			if ($searchResult) {
				$ramal = $searchResult.Ramal
				$site = $searchResult.Site
			}

			if ([string]::IsNullOrEmpty($ramal)) {
				Write-Host " Login/PIN não localizado." -ForegroundColor Yellow
				
				$retryOptions = @("Tentar novamente", "Digitar manualmente")
				$retryChoice = $null
				Select-FromMenu -Options $retryOptions -OutputVariable ([ref]$retryChoice) -Prompt "Deseja tentar novamente ou digitar o ramal manualmente?"

				if ($retryChoice -eq "Tentar novamente") {
					$user = (Read-Host " Informe o PIN ou usuário").Trim()
					$searchResult = Search-RamalPinTim -LookupValue $user
					if ($searchResult) {
						$ramal = $searchResult.Ramal
						$site = $searchResult.Site
					}
				}
			}
			while ([string]::IsNullOrEmpty($site)) {
				if ([string]::IsNullOrEmpty($ramal)) {
					$ramal = Read-Host " Ramal"
				}
				
				if ($ramal -notmatch '^\d{7}$') {
					Write-Host " Ramal inválido. Ramal deve ter 7 dígitos." -ForegroundColor Red
					$ramal = $null
					continue
				}

				$site = Get-TimSiteFromRamal -Ramal $ramal
				if ([string]::IsNullOrEmpty($site)) {
					Write-Host " Ramal inválido. Ramal TIM começa com 312 ou 382." -ForegroundColor Red
					$ramal = $null
					$site = $null
				}
			}

			Write-Host " Configurando Cisco para o ramal $ramal do site $site..." -ForegroundColor Cyan
			if (Test-Path $cisoRegPath32) {
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "AlternateDeviceName" -Type "DWord" -Value 1
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "NetworkTabUI" -Type "DWord" -Value 2
				Edit-Reg -Action "Create" -Path $cisoRegPath32 -Name "EnableHttpDownload" -Type "DWord" -Value 1
