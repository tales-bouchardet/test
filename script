function Get-SSCredential {
	$encryptedString = ""
	$storedSecure = ConvertTo-SecureString $encryptedString

	$inputSecure = Read-Host " Senha" -AsSecureString
	Write-Host ""
	
	$storedPlain = (New-Object System.Net.NetworkCredential("", $storedSecure)).Password
	$inputPlain  = (New-Object System.Net.NetworkCredential("", $inputSecure)).Password

	if ($storedPlain -eq $inputPlain) {
		return $true
	} else {
		Write-Host " Senha incorreta. Ação cancelada." -ForegroundColor Red
		return $false
	}
}
function Get-ActiveUser {
	$rawUser = (query user | Select-String 'Ativo|Active' | ForEach-Object { ($_ -split '\s+')[0] })
	return $rawUser.TrimStart('>')
}

function Get-ActiveUserSid {
	$user = Get-ActiveUser
	return (Get-ItemProperty 'HKLM:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\ProfileList\*' | Where-Object { $_.ProfileImagePath -eq "C:\Users\$user" }).PSChildName
}

function Edit-Reg {
	param(
		[Parameter(Mandatory=$false)][ValidateSet("Create","Remove")][string]$Action = "Create",
		[Parameter(Mandatory=$true)][string]$Path,
		[Parameter(Mandatory=$false)][ValidateSet("Item","Property")][string]$Target = "Property",
		[Parameter(Mandatory=$false)][Alias("Name")][string]$PName,
		[Parameter(Mandatory=$false)][ValidateSet("DWord","String")][string]$Type,
		[Parameter(Mandatory=$false)]$Value
	)
				
	$sid = Get-ActiveUserSid
	
	$regPath = if ($Path -like 'HKCU:\*') {
		$Path -replace '^HKCU:', "HKU:\$sid"
	} elseif ($Path -like 'ADM:\*') {
		$Path -replace '^ADM:', "HKCU:"
	} else {
		$Path
	}
	if ($Action -eq "Remove") {
		try {
			if ($Target -eq "Item") {
				Remove-Item -Path $regPath -Recurse -Force -ErrorAction SilentlyContinue
			} else {
				Remove-ItemProperty -Path $regPath -Name $PName -ErrorAction SilentlyContinue
			}
		} catch {
			Write-Host ("Erro ao remover a chave: {0}" -f $_.Exception.Message) -ForegroundColor Red
		}
		return
	}
	
	if (-not (Test-Path $regPath)) { New-Item -Path $regPath -Force | Out-Null }
	if ($Target -ne "Property") { return }
	try {
		if ($Type -eq "DWord") {
			New-ItemProperty -Path $regPath -Name $PName -Value ([int]$Value) -PropertyType DWord -Force | Out-Null
		} else {
			New-ItemProperty -Path $regPath -Name $PName -Value ([string]$Value) -PropertyType String -Force | Out-Null
		}
	} catch {
		Write-Host ("Erro ao criar/editar a chave: {0}" -f $_.Exception.Message) -ForegroundColor Red
	}
}

function Remove-FSItem {
	param(
		[Parameter(Mandatory=$true)][string]$Path
	)

	try {
		Remove-Item -Path $Path -Recurse -Force -ErrorAction SilentlyContinue
	} catch {
		Write-Host (" Erro ao remover item do sistema de arquivos: {0}" -f $_.Exception.Message) -ForegroundColor Red
	}
}

function Select-FromMenu {
	param(
		[Parameter(Mandatory=$true)][array]$Options,
		[Parameter(Mandatory=$true)][ref]$OutputVariable,
		[Parameter(Mandatory=$true)][string]$Prompt
	)

	$selectedIndex = 0

	function Write-OptionItem {
		param(
			[int]$Index,
			[bool]$IsSelected,
			[int]$TopLine
		)

		[Console]::SetCursorPosition(0, $TopLine + $Index)
		$label = "  $($Options[$Index])"
		$lineText = $label.PadRight([Math]::Max([Console]::WindowWidth - 1, $label.Length))
		if ($IsSelected) {
			Write-Host " > $lineText" -ForegroundColor Green -NoNewline
		} else {
			Write-Host "   $lineText" -ForegroundColor White -NoNewline
		}
	}

	Clear-Host
	Write-Host ""
	Write-Host " $Prompt" -ForegroundColor Cyan
	Write-Host ""
	$menuTop = [Console]::CursorTop

	for ($i = 0; $i -lt $Options.Count; $i++) {
		Write-OptionItem -Index $i -IsSelected ($i -eq $selectedIndex) -TopLine $menuTop
	}

	[Console]::CursorVisible = $false
	try {
		:KeyLoop while ($true) {
			$key = [Console]::ReadKey($true)
			switch ($key.Key) {
				"UpArrow" {
					$previousIndex = $selectedIndex
					if ($selectedIndex -gt 0) { $selectedIndex-- } else { $selectedIndex = $Options.Count - 1 }
					Write-OptionItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
					Write-OptionItem -Index $selectedIndex -IsSelected $true -TopLine $menuTop
				}
				"DownArrow" {
					$previousIndex = $selectedIndex
					if ($selectedIndex -lt ($Options.Count - 1)) { $selectedIndex++ } else { $selectedIndex = 0 }
					Write-OptionItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
					Write-OptionItem -Index $selectedIndex -IsSelected $true -TopLine $menuTop
				}
				"Enter" {
					$OutputVariable.Value = $Options[$selectedIndex]
					break KeyLoop
				}
				"Escape" {
					break KeyLoop
				}
			}
		}
	} finally {
		[Console]::CursorVisible = $true
	}
	Clear-Host
}

function Show-FirstMenu {
	param(
		[array]$Items,
		[int]$SelectedIndex = 0
	)

	function Write-MenuItem {
		param(
			[int]$Index,
			[bool]$IsSelected,
			[int]$TopLine
		)

		[Console]::SetCursorPosition(0, $TopLine + $Index)
		$label = "  $($Items[$Index].Nome)"
		$lineText = $label.PadRight([Math]::Max([Console]::WindowWidth - 1, $label.Length))
		if ($IsSelected) {
			Write-Host " > $lineText" -ForegroundColor Green -NoNewline
		} else {
			Write-Host "   $lineText" -ForegroundColor White -NoNewline
		}
	}

	while ($true) {
		Clear-Host
		Write-Host ""
		Write-Host " ↑ e ↓ para navegar, Enter para executar, Esc para sair." -ForegroundColor Cyan
		Write-Host " Enter para executar, Esc para sair." -ForegroundColor Cyan
		Write-Host ""
		$menuTop = [Console]::CursorTop

		for ($i = 0; $i -lt $Items.Count; $i++) {
			Write-MenuItem -Index $i -IsSelected ($i -eq $SelectedIndex) -TopLine $menuTop
		}

		[Console]::CursorVisible = $false
		try {
			:KeyLoop while ($true) {
				$key = [Console]::ReadKey($true)
				switch ($key.Key) {
					"UpArrow" {
						$previousIndex = $SelectedIndex
						if ($SelectedIndex -gt 0) { $SelectedIndex-- } else { $SelectedIndex = $Items.Count - 1 }
						Write-MenuItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
						Write-MenuItem -Index $SelectedIndex -IsSelected $true -TopLine $menuTop
					}
					"DownArrow" {
						$previousIndex = $SelectedIndex
						if ($SelectedIndex -lt ($Items.Count - 1)) { $SelectedIndex++ } else { $SelectedIndex = 0 }
						Write-MenuItem -Index $previousIndex -IsSelected $false -TopLine $menuTop
						Write-MenuItem -Index $SelectedIndex -IsSelected $true -TopLine $menuTop
					}
					"Enter" {
						break KeyLoop
					}
					"Escape" {
						return
					}
				}
			}
		} finally {
			[Console]::CursorVisible = $true
		}

		Clear-Host
		$selected = $Items[$SelectedIndex]
		Write-Host (" Executando: {0}" -f $selected.Nome) -ForegroundColor Cyan
		Write-Host "-------------------------------------------" -ForegroundColor DarkGray
		try {
			& $selected.Acao
		} catch {
			Write-Host ""
			Write-Host (" Erro: {0}" -f $_.Exception.Message) -ForegroundColor Red
		}
		Write-Host ""
		Write-Host " Pressione qualquer tecla para voltar ao menu..." -ForegroundColor Gray
		[void][Console]::ReadKey($true)
		$SelectedIndex = 0
	}
}

